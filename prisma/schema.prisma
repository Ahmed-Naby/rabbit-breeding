// RabbitTrack — breeding farm management schema
// Notes:
//  - "Enum-like" fields are kept as String with a fixed allowed-value set
//    enforced in the app via Zod (see src/lib/enums.ts) rather than native
//    Postgres enums, for parity with the SQLite-era schema.
//  - Money is stored as integer cents (amountCents), weight as integer grams —
//    never floats — to avoid rounding drift in financial and growth math.
//  - Dates are stored in UTC and displayed in local time by the UI.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// One settings row per farm (was a single global row with id=1 before
/// multi-farm). Holds display/unit prefs and breeding config so they can be
/// changed without code edits.
model Settings {
  farmId                   String    @id
  farm                     Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)
  weightUnit               String    @default("kg") // "kg" | "lb_oz"
  gestationDays            Int       @default(31) // mating -> expected kindling offset
  gestationWindowDays      Int       @default(3) // +/- days for the "due window" on the calendar
  pregnancyTestDays        Int       @default(10) // mating -> earliest pregnancy test (palpation) offset
  weaningDays              Int       @default(28) // kindling -> earliest weaning offset
  nestBoxDays              Int       @default(27) // mating -> earliest nest-box installation offset
  matingWeightGrams        Int       @default(3000) // minimum weight to count as ready-to-breed vs. still "سلالة"
  rebreedAfterKindlingDays Int       @default(0) // kindling -> earliest rebreed offset (0=مكثف, 15=نصف مكثف, 30=طبيعي)
  currency                 String    @default("USD")
  // Set (to now()) whenever the "wipe online database" danger-zone action
  // runs. Returned to every client on every pull/bootstrap (Settings is
  // always sent in full); a device compares this against the resetAt it
  // last saw locally to detect that the server was wiped out from under it
  // and needs a full local wipe + re-bootstrap rather than a normal
  // incremental pull (which only ever adds/updates rows, never notices
  // deletions).
  dataResetAt              DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
}

/// A rabbit. Soft-deleted via `status` (never hard-deleted) to preserve pedigree.
/// Parentage source of truth is sireId/damId; auto-populated from the litter when
/// a kit is promoted, but the FK is authoritative (supports acquired rabbits whose
/// parents are known but were never bred on this farm).
model Rabbit {
  // Type-optional so call sites never mention farms; the Prisma extension
  // injects the real farmId on every create, and the FK on farmId makes a
  // missed injection fail loudly ("" matches no Farm) instead of leaking.
  farmId String @default("")
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  id             String    @id @default(cuid())
  // Buck and doe numbering are separate sequences (a buck and a doe may share
  // a number), but numbers don't repeat within the same sex. Null means this
  // rabbit is still a "سلالة" (juvenile, sex known but not yet promoted) —
  // assigning a tagId via the quick-add finalize action IS the promotion.
  tagId          String? // rabbit/cage number, up to 10 chars, digits and letters (tattoo / ear ID)
  // Set automatically (see setRabbitStatusOp) when a tagged rabbit's status
  // moves to "deceased": captures her old tagId + death date for display,
  // while tagId itself is cleared to null so the number is immediately free
  // for a new rabbit of the same sex — @@unique([tagId, sex]) allows any
  // number of NULLs. Free-text, not validated by tagIdSchema (it's
  // system-generated, never typed into a form).
  retiredTagId   String?
  breed          String?
  color          String?
  sex            String    @default("unknown") // "buck" | "doe" | "unknown"
  dateOfBirth    DateTime?
  status         String    @default("active") // "active" | "sold" | "culled" | "deceased" | "reference"
  // Manual reproductive state, meaningful for does only. Set exclusively via the six
  // action buttons on the does page (mate/pregnant/negative/kindle/wean/exclude) —
  // never auto-derived from Breeding/Litter data.
  doeState       String    @default("empty") // "empty" | "bred" | "pregnant" | "nursing" | "excluded"
  cage           String? // cage / hutch number
  // How this rabbit entered the herd — "external" (bought in, added straight
  // via the top add-mother/add-buck form) vs "farm" (registered as a سلالة on
  // /stock, or a promoted litter kit). Null for legacy rows predating this field.
  origin         String?
  // A سلالة stays in the stock/nursery pen (raised there, cage + weight
  // tracked) for a while — often months — before someone explicitly decides
  // she/he's ready to move to the mothers/bucks waiting-for-tag pen. False
  // keeps a tagId-less rabbit on /stock regardless of cage/weight; flipped to
  // true only via the explicit "نقل إلى العنبر" button (see promoteToHerdPen),
  // never automatically just because a cage number was entered.
  movedToHerdPen Boolean   @default(false)
  acquiredDate   DateTime?
  acquiredFrom   String?
  notes          String?
  photoUrl       String?

  // Pedigree (self-relations). SetNull so a soft/rare hard delete never orphans FKs.
  sireId         String?
  sire           Rabbit?  @relation("Sire", fields: [sireId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  damId          String?
  dam            Rabbit?  @relation("Dam", fields: [damId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  siredOffspring Rabbit[] @relation("Sire")
  boreOffspring  Rabbit[] @relation("Dam")

  // Which litter this rabbit was born in (null for acquired / foundation stock).
  litterId String?
  litter   Litter? @relation(fields: [litterId], references: [id], onDelete: SetNull)

  // Set when this rabbit was registered on /stock as a سلالة — the "retained"
  // KitStockMovement that deducted it from the available weaned-kit pool.
  kitStockMovement KitStockMovement?

  // Breeding participation
  breedingsAsBuck Breeding[] @relation("Buck")
  breedingsAsDoe  Breeding[] @relation("Doe")

  // Pregnancy-test history. Append-only — unlike Breeding (whose row is
  // reused/overwritten on the doe's next mating), a log row is never
  // touched again once written, so negative results are never lost.
  pregnancyTestLogsAsBuck PregnancyTestLog[] @relation("PregnancyTestLogBuck")
  pregnancyTestLogsAsDoe  PregnancyTestLog[] @relation("PregnancyTestLogDoe")

  // Kindling history. Same append-only reasoning as PregnancyTestLog — the
  // Breeding row's actualKindlingDate gets wiped back to null the next time
  // the same doe is mated (see markMated's reuse branch), so without this
  // snapshot a doe's birth history would shrink to just her current cycle.
  kindlingLogsAsBuck KindlingLog[] @relation("KindlingLogBuck")
  kindlingLogsAsDoe  KindlingLog[] @relation("KindlingLogDoe")

  // Fostering (kit transfer) history, both directions. Append-only, same
  // reasoning as PregnancyTestLog/KindlingLog — but two-sided (fromDoe/toDoe)
  // by nature, so it can never be folded into a Breeding row at all.
  fosterLogsFrom FosterLog[] @relation("FosterLogFrom")
  fosterLogsTo   FosterLog[] @relation("FosterLogTo")

  // Logs
  weightRecords WeightRecord[]
  healthRecords HealthRecord[]
  transactions  Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([farmId, tagId, sex])
  @@index([status])
  @@index([sex])
  @@index([breed])
  @@index([sireId])
  @@index([damId])
  @@index([doeState])
  @@index([farmId])
}

/// A mating record. expectedKindlingDate is computed at write time from
/// Settings.gestationDays; the +/- window is applied at read time for the calendar.
model Breeding {
  // Type-optional so call sites never mention farms; the Prisma extension
  // injects the real farmId on every create, and the FK on farmId makes a
  // missed injection fail loudly ("" matches no Farm) instead of leaking.
  farmId String @default("")
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  id                   String    @id @default(cuid())
  // Nullable: the does board starts a mating without picking a buck (pairings
  // aren't tracked automatically anymore) — the farm types in the buck's tag
  // number afterward if/when they want to record it, or leaves it blank.
  buckId               String?
  buck                 Rabbit?   @relation("Buck", fields: [buckId], references: [id], onDelete: Restrict)
  doeId                String
  doe                  Rabbit    @relation("Doe", fields: [doeId], references: [id], onDelete: Restrict)
  // Nullable: cleared back to null when a mating attempt fails (see the
  // "فشل التلقيح" action on the does board), leaving the row date-less
  // rather than deleting the historical buck/doe pairing.
  matingDate           DateTime?
  expectedKindlingDate DateTime
  actualKindlingDate   DateTime?
  // Nest box installed for this cycle — cleared back to null wherever
  // matingDate itself is reset/overwritten (markMated's reuse branch,
  // markMatingFailed, clearDoeRow), since it's a per-cycle checklist item,
  // not permanent history (unlike PregnancyTestLog/KindlingLog).
  nestBoxDate          DateTime?
  outcome              String    @default("pending") // "pending" | "successful" | "failed" | "not_pregnant"
  // Early pregnancy check, done ~10 days after mating — separate from the final
  // kindling `outcome` which is only known ~31 days later.
  pregnancyTestResult  String    @default("pending") // "pending" | "positive" | "negative"
  notes                String?

  litter Litter? // one litter per mating

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([outcome])
  @@index([expectedKindlingDate])
  @@index([doeId])
  @@index([buckId])
  @@index([farmId])
}

/// A permanent pregnancy-test result. Written once, at the moment "عشار"/"سالبة"
/// is pressed, and never updated afterward — snapshots matingDate/buckId off the
/// Breeding row at that instant, since that row gets reused (overwritten) the
/// next time the same doe is mated, which would otherwise silently erase history.
model PregnancyTestLog {
  // Type-optional so call sites never mention farms; the Prisma extension
  // injects the real farmId on every create, and the FK on farmId makes a
  // missed injection fail loudly ("" matches no Farm) instead of leaking.
  farmId String @default("")
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  id         String   @id @default(cuid())
  doeId      String
  doe        Rabbit   @relation("PregnancyTestLogDoe", fields: [doeId], references: [id], onDelete: Restrict)
  buckId     String?
  buck       Rabbit?  @relation("PregnancyTestLogBuck", fields: [buckId], references: [id], onDelete: Restrict)
  matingDate DateTime
  testDate   DateTime @default(now())
  result     String // "positive" | "negative"
  createdAt  DateTime @default(now())

  @@index([doeId])
  @@index([testDate])
  @@index([farmId])
}

/// A permanent kindling (birth) record. Written once, at the moment "ولادة"
/// is pressed, and never updated afterward — snapshots matingDate/buckId off
/// the Breeding row at that instant, since that row (and its
/// actualKindlingDate) gets reused/overwritten the next time the same doe is
/// mated, which would otherwise silently erase this birth from history.
model KindlingLog {
  // Type-optional so call sites never mention farms; the Prisma extension
  // injects the real farmId on every create, and the FK on farmId makes a
  // missed injection fail loudly ("" matches no Farm) instead of leaking.
  farmId String @default("")
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  id           String    @id @default(cuid())
  doeId        String
  doe          Rabbit    @relation("KindlingLogDoe", fields: [doeId], references: [id], onDelete: Restrict)
  buckId       String?
  buck         Rabbit?   @relation("KindlingLogBuck", fields: [buckId], references: [id], onDelete: Restrict)
  matingDate   DateTime?
  kindlingDate DateTime
  createdAt    DateTime  @default(now())

  @@index([doeId])
  @@index([kindlingDate])
  @@index([farmId])
}

/// A permanent record of nursing kits transferred (fostered) from one doe's
/// current litter to another's, to equalize litter sizes. Written once, at
/// the moment "حفظ" is pressed, and never updated — snapshots the doe pair
/// and count directly rather than linking to a Breeding/Litter row, since
/// those rows get reused/reset on the next mating cycle.
model FosterLog {
  // Type-optional so call sites never mention farms; the Prisma extension
  // injects the real farmId on every create, and the FK on farmId makes a
  // missed injection fail loudly ("" matches no Farm) instead of leaking.
  farmId String @default("")
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  id        String   @id @default(cuid())
  fromDoeId String
  fromDoe   Rabbit   @relation("FosterLogFrom", fields: [fromDoeId], references: [id], onDelete: Restrict)
  toDoeId   String
  toDoe     Rabbit   @relation("FosterLogTo", fields: [toDoeId], references: [id], onDelete: Restrict)
  count     Int
  date      DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([fromDoeId])
  @@index([toDoeId])
  @@index([date])
  @@index([farmId])
}

/// Registered rabbit breed/type names, managed from Settings. Rabbit.breed
/// stores the name directly (not a FK) — kept as free text so existing rows
/// with an unregistered breed string never break; this table is just a
/// curated menu that powers the breed dropdown pickers app-wide.
model Breed {
  // Type-optional so call sites never mention farms; the Prisma extension
  // injects the real farmId on every create, and the FK on farmId makes a
  // missed injection fail loudly ("" matches no Farm) instead of leaking.
  farmId String @default("")
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  @@unique([farmId, name])
  @@index([farmId])
}

/// The outcome of a successful mating. Counts-first: individual kits are optional
/// and become Rabbit rows (linked back via Rabbit.litterId) when tagged.
model Litter {
  // Type-optional so call sites never mention farms; the Prisma extension
  // injects the real farmId on every create, and the FK on farmId makes a
  // missed injection fail loudly ("" matches no Farm) instead of leaking.
  farmId String @default("")
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  id                 String    @id @default(cuid())
  breedingId         String    @unique
  breeding           Breeding  @relation(fields: [breedingId], references: [id], onDelete: Cascade)
  kindlingDate       DateTime
  bornAlive          Int       @default(0)
  bornDead           Int       @default(0)
  weaned             Int? // number that survived to weaning
  weaningDate        DateTime?
  weaningWeightGrams Int? // total litter weight at weaning
  notes              String?

  kits Rabbit[] // rabbits promoted from this litter

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kindlingDate])
  @@index([farmId])
}

/// A weight measurement. Stored canonically in grams; UI converts to kg or lb/oz.
model WeightRecord {
  // Type-optional so call sites never mention farms; the Prisma extension
  // injects the real farmId on every create, and the FK on farmId makes a
  // missed injection fail loudly ("" matches no Farm) instead of leaking.
  farmId String @default("")
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  id          String   @id @default(cuid())
  rabbitId    String
  rabbit      Rabbit   @relation(fields: [rabbitId], references: [id], onDelete: Cascade)
  date        DateTime
  weightGrams Int
  notes       String?
  createdAt   DateTime @default(now())
  // Needed so the sync pull endpoint can find rows changed since a cursor —
  // this is the one non-Breeding/Rabbit/Litter model actually mutated in
  // place today (saveQuickRabbitWeight/finalizeMother/finalizeBuck).
  updatedAt   DateTime @updatedAt

  @@index([rabbitId, date])
  @@index([farmId])
}

/// A health event. nextDueDate drives the overdue/upcoming reminders on the dashboard.
model HealthRecord {
  // Type-optional so call sites never mention farms; the Prisma extension
  // injects the real farmId on every create, and the FK on farmId makes a
  // missed injection fail loudly ("" matches no Farm) instead of leaking.
  farmId String @default("")
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  id          String    @id @default(cuid())
  rabbitId    String
  rabbit      Rabbit    @relation(fields: [rabbitId], references: [id], onDelete: Cascade)
  date        DateTime
  type        String // "vaccination" | "treatment" | "illness" | "deworming" | "checkup"
  description String
  nextDueDate DateTime?
  createdAt   DateTime  @default(now())

  @@index([rabbitId, date])
  @@index([nextDueDate])
  @@index([farmId])
}

/// Income/expense entry. rabbitId null = farm-wide (feed, equipment, vet, etc).
/// Amount is integer cents; type sign is implied by `type`, amount is always positive.
model Transaction {
  // Type-optional so call sites never mention farms; the Prisma extension
  // injects the real farmId on every create, and the FK on farmId makes a
  // missed injection fail loudly ("" matches no Farm) instead of leaking.
  farmId String @default("")
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  id          String   @id @default(cuid())
  rabbitId    String?
  rabbit      Rabbit?  @relation(fields: [rabbitId], references: [id], onDelete: SetNull)
  date        DateTime
  type        String // "income" | "expense"
  category    String // "sale" | "purchase" | "feed" | "vet" | "equipment" | "other"
  amountCents Int
  notes       String?
  createdAt   DateTime @default(now())

  kitStockMovement KitStockMovement?

  @@index([date])
  @@index([type])
  @@index([category])
  @@index([rabbitId])
  @@index([farmId])
}

/// Farm-wide ledger of weaned-kit stock movements (batch counts, not tied to
/// individually tagged rabbits, except "retained"). Positive "wean" entries
/// aren't stored here — they're derived on read from Litter.weaned grouped by
/// weaningDate — this table only stores the deductions: sales (with
/// weight/price, mirrored into a Transaction), post-weaning deaths, and kits
/// kept for breeding (mirrored into a Rabbit, one movement per rabbit).
model KitStockMovement {
  // Type-optional so call sites never mention farms; the Prisma extension
  // injects the real farmId on every create, and the FK on farmId makes a
  // missed injection fail loudly ("" matches no Farm) instead of leaking.
  farmId String @default("")
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  id              String   @id @default(cuid())
  date            DateTime
  type            String // "sale" | "death" | "retained"
  count           Int // always a positive quantity; sign is a display-only concern
  weightGrams     Int? // total weight sold — "sale" only
  pricePerKgCents Int? // price/kg on the sale day — "sale" only
  amountCents     Int? // weightGrams * pricePerKgCents / 1000, rounded — "sale" only

  transactionId String?      @unique
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  // "retained" only — the specific سلالة this kit became. Cascades so
  // deleting the rabbit (e.g. a mistaken entry) also undoes the deduction.
  rabbitId String? @unique
  rabbit   Rabbit? @relation(fields: [rabbitId], references: [id], onDelete: Cascade)

  notes     String?
  createdAt DateTime @default(now())

  @@index([date])
  @@index([type])
  @@index([farmId])
}

/// A device (phone/tablet) participating in offline sync. Bound to the farm
/// it mirrors; userId records who logged the device in (null for devices
/// that synced under the legacy shared-secret scheme before auth existed).
model SyncDevice {
  id         String    @id @default(cuid())
  farmId     String
  farm       Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  label      String?
  lastSyncAt DateTime?
  createdAt  DateTime  @default(now())

  operations SyncOperation[]

  @@index([farmId])
}

/// An account. Farm membership (and role) lives in FarmMember, so one
/// account can own one farm and work on another.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String // scrypt, "salt:hash" hex (see src/lib/auth/password.ts)
  name         String?
  createdAt    DateTime @default(now())

  memberships  FarmMember[]
  deviceTokens DeviceToken[]
  syncDevices  SyncDevice[]
}

/// A tenant. Every farm-data row carries farmId; deleting a farm cascades
/// through everything it owns.
model Farm {
  id        String   @id @default(cuid())
  name      String
  location  String? // free-text farm location/place, shown & editable in settings
  createdAt DateTime @default(now())

  members           FarmMember[]
  settings          Settings?
  syncDevices       SyncDevice[]
  rabbits           Rabbit[]
  breedings         Breeding[]
  litters           Litter[]
  weightRecords     WeightRecord[]
  healthRecords     HealthRecord[]
  transactions      Transaction[]
  kitStockMovements KitStockMovement[]
  breeds            Breed[]
  pregnancyTestLogs PregnancyTestLog[]
  kindlingLogs      KindlingLog[]
  fosterLogs        FosterLog[]
}

/// Membership + role. "owner" can manage members and use the danger zone
/// (wipe/restore/reset); "worker" records day-to-day farm operations only.
model FarmMember {
  id        String   @id @default(cuid())
  farmId    String
  farm      Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String // "owner" | "worker" (displayed as مشرف/Supervisor)
  // Page-level UI permissions for workers: array of route hashes the member
  // may see (null = all pages). Enforced by the app shell — the sync API
  // itself stays role-based (owner vs worker), not per-page.
  allowedPages Json?
  createdAt DateTime @default(now())

  @@unique([farmId, userId])
  @@index([userId])
}

/// An opaque login token held by a device (web session cookie or the mobile
/// app's stored credential). Only the sha256 of the token is stored — a DB
/// leak can't be replayed as logins.
model DeviceToken {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  label      String?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
}

/// Idempotency + audit ledger for offline-queued business operations
/// replayed from a SyncDevice. clientOpId is generated on-device at enqueue
/// time; looking it up first on push is what makes resending a push batch
/// safe after a partial network failure (already-applied ops are skipped,
/// not re-run).
model SyncOperation {
  id            String     @id @default(cuid())
  clientOpId    String     @unique
  deviceId      String
  device        SyncDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  opType        String
  payload       Json
  clientAt      DateTime
  status        String // "applied" | "rejected"
  resultMessage String?
  appliedAt     DateTime?
  createdAt     DateTime   @default(now())

  @@index([deviceId])
  @@index([opType])
}
